<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Bootstrap first -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Icons or fonts -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">

  <!-- Your custom CSS last (overrides Bootstrap) -->
  <link href="/css/style.css" rel="stylesheet">

  <title>One Klick Purchase</title>
</head>


<!-- Promo Banner Enhancement ningxin-->
<div class="bg-danger text-white text-center py-1 fw-bold small">
  🎉 Welcome to One Klick Purchase! Get $10 off your first order with code: <strong>FIRST10</strong>
</div>

<!-- Main Navbar -->
<nav id="headernavbar" class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
  <div class="container">
    <!-- Brand -->
    <a id="headernavbarbrand" class="navbar-brand fw-bold font-instrument fs-3" href="/">One Klick Purchase</a>

    <!-- Toggler button for Mobile -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Collapsible Menu ningxin-->
    <div class="collapse navbar-collapse" id="collapsibleNavbar">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <!-- Home -->
        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>

        <!-- Shop All -->
        <li class="nav-item">
          <a class="nav-link" href="/products">Shop All</a>
        </li>

        <!-- Categories Dropdown (Ning Xin) -->
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" id="categoriesDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Categories
          </a>
          <ul class="dropdown-menu" aria-labelledby="categoriesDropdown">
            <% 
              const defaultCategories = [
                'toys & collectibles', 'computers & tech', "women's fashion", 
                "men's fashion", 'video gaming', 'furniture & home living', 
                'sports & wellness', 'tickets & vouchers', 'others'
              ];
              const catList = (typeof categories !== 'undefined' && categories.length > 0) ? categories : defaultCategories;
            %>
            <% catList.forEach(cat => { %>
              <li>
                <a class="dropdown-item text-capitalize" href="/products?category=<%= encodeURIComponent(cat) %>">
                  <%= cat %>
                </a>
              </li>
            <% }) %>
          </ul>
        </li>
      </ul>

      <!-- Product Search Bar (Ning Xin) -->
      <form class="d-flex me-lg-3 my-2 my-lg-0" action="/products" method="GET">
        <input class="form-control me-2" type="search" name="search" placeholder="Search products..." required>
        <button class="btn btn-outline-light" type="submit">Search</button>
      </form>

      <!-- User Auth & Quick Links -->
      <ul class="navbar-nav">
        <% if (typeof user !== 'undefined' && user) { %>

          <li class="nav-item dropdown ms-lg-2">
            <a class="nav-link dropdown-toggle text-white fw-semibold" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
              Hi, <%= user.username %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
    <li><a class="dropdown-item" href="/profile">Profile</a></li>
        <li><a class="dropdown-item" href="/userproducts">My Listings</a></li>
    <li><a class="dropdown-item" href="/addProduct">Add Listing</a></li>
        <li><a class="dropdown-item" href="/wishlist">Wishlist</a></li>
    <li><a class="dropdown-item" href="/cart">My Cart</a></li>
    <li><hr class="dropdown-divider"></li>
    <li><a class="dropdown-item text-danger" href="/logout">Sign Out</a></li>
</ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/login">Log In</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/register">Register</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
