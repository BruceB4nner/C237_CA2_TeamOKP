<head>
  <title>One Klick Purchase</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
</head>
<body>

<!-- Promo Banner -->
<div class="bg-danger text-white text-center py-1">
  🎉 Get $10 off your first purchase!
</div>

<nav id="headernavbar" class="navbar navbar-expand-sm navbar-dark bg-dark">
  <div class="container-fluid">
    <a id="headernavbarbrand" class="navbar-brand">One Klick Purchase</a>

    <!-- Toggler button -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Collapsible menu -->
    <div class="collapse navbar-collapse" id="collapsibleNavbar">
      <ul class="navbar-nav ms-auto">

        <!-- Home -->
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>

        <!-- Shop All -->
        <li class="nav-item"><a class="nav-link" href="/products">Shop All</a></li>

        <!-- Categories Dropdown -->
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" id="categoriesDropdown" role="button" data-bs-toggle="dropdown">
            Categories
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/tops">Tops</a></li>
            <li><a class="dropdown-item" href="/dresses">Dresses</a></li>
            <li><a class="dropdown-item" href="/sets">Matching Sets</a></li>
            <li><a class="dropdown-item" href="/bottoms">Bottoms</a></li>
          </ul>
        </li>

        <!-- Wishlist -->
        <li class="nav-item"><a class="nav-link" href="/wishlist">Wishlist</a></li>

        <!-- User Login/Logout -->
        <% if (user) { %>
          <li class="nav-item"><span class="nav-link text-white">Hi, <%= user.username %></span></li>
          <li class="nav-item"><a class="nav-link" href="/logout">Sign Out</a></li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/login">Log In</a></li>
        <% } %>

      </ul>
    </div>
  </div>
</nav>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
