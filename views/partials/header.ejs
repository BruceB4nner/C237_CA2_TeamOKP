<head>
  <title>One Klick Purchase</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">


</head>
<body>

<!-- Promo Banner -->
<div class="bg-danger text-white text-center py-1">
  🎉 Get $10 off your first purchase!
</div>

<nav id="headernavbar" class="navbar navbar-expand-sm navbar-dark bg-dark">
  <div class="container-fluid">
    <a id="headernavbarbrand" class="navbar-brand" href="/">One Klick Purchase</a>

    <!-- Toggler button -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Collapsible menu -->
    <div class="collapse navbar-collapse" id="collapsibleNavbar">
      <ul class="navbar-nav ms-auto">

        <!-- Home -->
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>

        <!-- Shop All -->
        <li class="nav-item"><a class="nav-link" href="/products">Shop All</a></li>

        <!-- Categories Dropdown -->
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" id="categoriesDropdown" role="button" 
             data-bs-toggle="dropdown" aria-expanded="false">
            Categories
          </a>
          <ul class="dropdown-menu" aria-labelledby="categoriesDropdown">
            <li><a class="dropdown-item" href="/toys-collectibles">Toys & Collectibles</a></li>
            <li><a class="dropdown-item" href="/computers-tech">Computers & Tech</a></li>
            <li><a class="dropdown-item" href="/womens-fashion">Women's Fashion</a></li>
            <li><a class="dropdown-item" href="/mens-fashion">Men's Fashion</a></li>
            <li><a class="dropdown-item" href="/video-gaming">Video Gaming</a></li>
            <li><a class="dropdown-item" href="/furniture-home">Furniture & Home Living</a></li>
            <li><a class="dropdown-item" href="/health-nutrition">Health & Nutrition</a></li>
            <li><a class="dropdown-item" href="/tickets-vouchers">Tickets & Vouchers</a></li>
            <li><a class="dropdown-item" href="/others">Others</a></li>




          </ul>
        </li>

        <!-- Wishlist -->
        <li class="nav-item"><a class="nav-link" href="/wishlist">Wishlist</a></li>

        <!-- User Login/Logout -->
        <% if (user) { %>
  <li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle text-white" href="#" id="userDropdown" role="button"
       data-bs-toggle="dropdown">
      Hi, <%= user.username %>
    </a>
    <ul class="dropdown-menu dropdown-menu-end">
      <li><a class="dropdown-item" href="/profile">Profile</a></li>
      <li><a class="dropdown-item" href="/orders">My Orders</a></li>
      <li><hr class="dropdown-divider"></li>
      <li><a class="dropdown-item text-danger" href="/logout">Sign Out</a></li>
    </ul>
  </li>
<% } else { %>
  <li class="nav-item"><a class="nav-link" href="/login">Log In</a></li>
<% } %>


      </ul>
    </div>
  </div>
</nav>
</body>
