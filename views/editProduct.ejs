<!DOCTYPE html>
<html>

<head>
    <title>Edit Product</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include('partials/header.ejs') %>

<div class="container mt-5">

    <h2 class="mb-4" style="font-family: Arial, sans-serif;">
    Edit Product
    </h2>

    <form action="/editProduct/<%= product.productId %>" method="POST">

        <!-- Product Name -->
        <div class="mb-3">
            <label class="form-label">Product Name</label>

            <input
                type="text"
                class="form-control"
                name="productName"
                value="<%= product.productName %>"
                required>
        </div>

        <!-- Category -->
        <div class="mb-3">
            <label class="form-label">Category</label>

            <select class="form-select" name="category" required>

                <option value="Toys & Collectibles" <%= product.category === 'Toys & Collectibles' ? 'selected' : '' %>>
                    🧸 Toys & Collectibles
                </option>

                <option value="Computers & Tech" <%= product.category === 'Computers & Tech' ? 'selected' : '' %>>
                    💻 Computers & Tech
                </option>

                <option value="Women's Fashion" <%= product.category === "Women's Fashion" ? 'selected' : '' %>>
                    👗 Women's Fashion
                </option>

                <option value="Men's Fashion" <%= product.category === "Men's Fashion" ? 'selected' : '' %>>
                    👔 Men's Fashion
                </option>

                <option value="Video Gaming" <%= product.category === 'Video Gaming' ? 'selected' : '' %>>
                    🎮 Video Gaming
                </option>

                <option value="Furniture & Home Living" <%= product.category === 'Furniture & Home Living' ? 'selected' : '' %>>
                    🛋️ Furniture & Home Living
                </option>

                <option value="Health & Nutrition" <%= product.category === 'Health & Nutrition' ? 'selected' : '' %>>
                    💊 Health & Nutrition
                </option>

                <option value="Tickets & Vouchers" <%= product.category === 'Tickets & Vouchers' ? 'selected' : '' %>>
                    🎟️ Tickets & Vouchers
                </option>

                <option value="Others" <%= product.category === 'Others' ? 'selected' : '' %>>
                    📦 Others
                </option>

            </select>

        </div>

        <!-- Description -->
        <div class="mb-3">

            <label class="form-label">Description</label>

            <textarea
                class="form-control"
                name="description"
                rows="4"
                required><%= product.description %></textarea>

        </div>

        <!-- Stock -->
        <div class="mb-3">

            <label class="form-label">Stock</label>

            <input
                type="number"
                class="form-control"
                name="stock"
                min="1"
                value="<%= product.stock %>"
                required>

        </div>

        <!-- Price -->
        <div class="mb-3">

            <label class="form-label">Price ($)</label>

            <input
                type="number"
                class="form-control"
                step="0.01"
                min="0"
                name="price"
                value="<%= product.price %>"
                required>

        </div>

        <!-- Image -->
        <div class="mb-3">

            <label class="form-label">Image URL</label>

            <input
                type="text"
                class="form-control"
                name="image"
                value="<%= product.image %>"
                required>

        </div>

        <button type="submit" class="btn btn-primary">
            Update Product
        </button>

        <a href="/products" class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>

<%- include('partials/footer.ejs') %>

</body>

</html>