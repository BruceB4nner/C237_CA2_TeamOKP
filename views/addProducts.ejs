<!DOCTYPE html>
<html>

<head>
    <title>Sell an Item</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
<%- include('partials/header.ejs') %>
<div class="container mt-5">

    <h2 class="mb-4">Create a New Listing</h2>

    <form action="/addProduct" method="POST">

        <!-- Product Name -->
        <div class="mb-3">
            <label class="form-label">Product Name</label>
            <input
                type="text"
                class="form-control"
                name="productName"
                placeholder="Enter product name"
                required>
        </div>

        <!-- Category -->
        <div class="mb-3">
            <label class="form-label">Category</label>

            <select class="form-select" name="category" required>

                <option value="">Select a Category</option>

                <option value="Toys & Collectibles">🧸 Toys & Collectibles</option>

                <option value="Computers & Tech">💻 Computers & Tech</option>

                <option value="Women's Fashion">👗 Women's Fashion</option>

                <option value="Men's Fashion">👔 Men's Fashion</option>

                <option value="Video Gaming">🎮 Video Gaming</option>

                <option value="Furniture & Home Living">🛋️ Furniture & Home Living</option>

                <option value="Health & Nutrition">💊 Health & Nutrition</option>

                <option value="Tickets & Vouchers">🎟️ Tickets & Vouchers</option>

                <option value="Others">📦 Others</option>

            </select>
        </div>

        <!-- Description -->
        <div class="mb-3">
            <label class="form-label">Description</label>

            <textarea
                class="form-control"
                name="description"
                rows="4"
                placeholder="Describe your item..."
                required></textarea>
        </div>

        <!-- Stock -->
        <div class="mb-3">
            <label class="form-label">Stock</label>

            <input
    type="number"
    class="form-control"
    name="stock"
    min="1"
    required>
        </div>

        <!-- Price -->
        <div class="mb-3">
            <label class="form-label">Price ($)</label>

            <input
                type="number"
                step="0.01"
                min="0"
                class="form-control"
                name="price"
                required>
        </div>

        <!-- Image -->
        <div class="mb-3">
            <label class="form-label">Image URL</label>

            <input
                type="text"
                class="form-control"
                name="image"
                placeholder="https://example.com/image.jpg"
                required>
        </div>

        <div class="d-flex gap-2">

            <button type="submit" class="btn btn-success">
                Post Listing
            </button>

            <a href="/products" class="btn btn-secondary">
                Cancel
            </a>

        </div>

    </form>

</div>
<%- include('partials/footer.ejs') %>
</body>

</html>