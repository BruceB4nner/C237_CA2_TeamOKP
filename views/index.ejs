<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="/css/style.css" rel="stylesheet"> 
  <title>One Klick Purchase</title>
</head>
<body>
  <%- include('partials/header.ejs') %>

  <main class="container my-5">
    <!-- About Section -->
    <section class="text-center mb-5">
      <h2 class="fw-bold">About One Klick Purchase</h2>
      <p class="lead text-muted mx-auto">
        We're a team of 5 youths who have decided to create our very own e‑commerce platform
        for users to buy and list items!
      </p>
    </section>

    <!-- Homepage Carousel (Ning Xin) -->
<div id="productCarousel" class="carousel slide my-5 shadow rounded overflow-hidden" data-bs-ride="carousel" data-bs-interval="4000">
  <div class="carousel-inner">
    <% products.forEach((product, index) => { %>
      <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
        <div class="row align-items-center justify-content-center">
          <!-- Left: Product image -->
          <div class="col-md-6 text-center position-relative">
  <img src="<%= product.image || 'https://via.placeholder.com/400' %>" 
       class="img-fluid rounded" 
       alt="<%= product.productName %>">

  <div class="product-label">
    <%= product.productName %>
  </div>
</div>


          <!-- Right: Product info + review -->
          <div class="col-md-6">
            <h4 class="fw-bold"><%= product.productName %></h4>
            <p class="fst-italic text-muted">
    "<%= product.comment %>"
</p>

<p class="text-warning">
    <% for(let i = 0; i < product.rating; i++) { %>★<% } %>
</p>

<small>— <%= product.username %></small>
            <a href="/products/<%= product.productId %>" class="btn btn-primary btn-sm mt-2">View Product</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Controls -->
  <button id="leftbutton" class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>
  <button id="rightbutton" class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>



    <!-- Categories Grid Section (Ning Xin) -->
    <section class="my-5">
      <h3 class="fw-bold mb-4 text-center">Shop by Category</h3>
      <div class="row g-3">
        <% 
          const categories = [
            'toys & collectibles', 'computers & tech', "women's fashion", 
            "men's fashion", 'video gaming', 'furniture & home living', 
            'sports & wellness', 'tickets & vouchers', 'others'
          ];
        %>
        <% categories.forEach(cat => { %>
          <div class="col-6 col-md-4 col-lg-3">
            <a href="/products?category=<%= encodeURIComponent(cat) %>" class="text-decoration-none">
              <div class="card text-center h-100 border-0 shadow-sm hover-shadow bg-light">
                <div class="card-body d-flex align-items-center justify-content-center p-3">
                  <h6 class="card-title text-capitalize text-dark mb-0 fw-semibold"><%= cat %></h6>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
    </section>

    <!-- Homepage Product Reviews (Kai Peng / Ning Xin Integration) -->
    <% if (typeof reviews !== 'undefined' && reviews.length > 0) { %>
      <section class="my-5 bg-light p-4 rounded">
        <h3 class="fw-bold mb-4 text-center">What Customers Are Saying</h3>
        <div class="row g-3">
          <% reviews.forEach(rev => { %>
            <div class="col-md-6 col-lg-3">
              <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                  <div class="text-warning mb-2">
                    <% for(let i = 0; i < rev.rating; i++) { %>★<% } %>
                  </div>
                  <p class="card-text small">"<%= rev.comment %>"</p>
                  <small class="text-muted">— <%= rev.username %> on <em><%= rev.product_name %></em></small>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>
  </main>

  <%- include('partials/footer.ejs') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
