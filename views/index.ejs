<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>One Klick Purchase</title>
</head>
<body>
  <%- include('partials/header.ejs') %>

  <main class="container my-5">
    <!-- About Section -->
    <section class="text-center mb-5">
      <h2 class="fw-bold">About One Klick Purchase</h2>
      <p class="lead text-muted mx-auto" style="max-width: 600px;">
        We're a team of 5 youths who have decided to create our very own e‑commerce platform
        for users to buy and list items!
      </p>
    </section>

    <!-- Homepage Carousel (Ning Xin) -->
    <% if (typeof products !== 'undefined' && products.length > 0) { %>
      <div id="productCarousel" class="carousel slide my-5 shadow rounded overflow-hidden" data-bs-ride="carousel" data-bs-interval="4000">
        <div class="carousel-inner">
          <% products.forEach((product, index) => { %>
            <div class="carousel-item <%= index === 0 ? 'active' : '' %>" style="height: 400px;">
              <img 
                src="<%= product.image || product.image_url || 'https://via.placeholder.com/800x400?text=No+Image' %>" 
                class="w-100 h-100 object-fit-cover d-block" 
                alt="<%= product.title || product.name %>"
              >
              <div class="carousel-caption bg-dark bg-opacity-75 rounded p-3">
                <h5 class="fw-bold"><%= product.title || product.name %></h5>
                <p class="small d-none d-md-block"><%= product.description %></p>
                <a href="/products/<%= product.id %>" class="btn btn-sm btn-light font-weight-bold">View Product</a>
              </div>
            </div>
          <% }) %>
        </div>
        
        <!-- Controls -->
        <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
          <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
          <span class="carousel-control-next-icon"></span>
        </button>
      </div>
    <% } %>

    <!-- Categories Grid Section (Ning Xin) -->
    <section class="my-5">
      <h3 class="fw-bold mb-4 text-center">Shop by Category</h3>
      <div class="row g-3">
        <% 
          const categories = [
            'toys & collectibles', 'computers & tech', "women's fashion", 
            "men's fashion", 'video gaming', 'furniture & home living', 
            'sports & wellness', 'tickets & vouchers', 'others'
          ];
        %>
        <% categories.forEach(cat => { %>
          <div class="col-6 col-md-4 col-lg-3">
            <a href="/products?category=<%= encodeURIComponent(cat) %>" class="text-decoration-none">
              <div class="card text-center h-100 border-0 shadow-sm hover-shadow bg-light">
                <div class="card-body d-flex align-items-center justify-content-center p-3">
                  <h6 class="card-title text-capitalize text-dark mb-0 fw-semibold"><%= cat %></h6>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
    </section>

    <!-- Homepage Product Reviews (Kai Peng / Ning Xin Integration) -->
    <% if (typeof reviews !== 'undefined' && reviews.length > 0) { %>
      <section class="my-5 bg-light p-4 rounded">
        <h3 class="fw-bold mb-4 text-center">What Customers Are Saying</h3>
        <div class="row g-3">
          <% reviews.forEach(rev => { %>
            <div class="col-md-6 col-lg-3">
              <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                  <div class="text-warning mb-2">
                    <% for(let i = 0; i < rev.rating; i++) { %>★<% } %>
                  </div>
                  <p class="card-text small">"<%= rev.comment %>"</p>
                  <small class="text-muted">— <%= rev.username %> on <em><%= rev.product_name %></em></small>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>
  </main>

  <%- include('partials/footer.ejs') %>

  <!-- dont add bootstrap bundle anywhere else -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
