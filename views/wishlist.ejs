<h2>My Wishlist</h2>

<% if(products.length === 0){ %>

<p>Your wishlist is empty.</p>

<% } else { %>

<% products.forEach(product => { %>

<div class="card mb-3">

    <h4><%= product.name %></h4>

    <p>$<%= product.price %></p>

    <img src="/uploads/<%= product.image %>" width="200">

    <form action="/wishlist/delete/<%= product.id %>" method="POST">
        <button class="btn btn-danger">
            Remove
        </button>
    </form>

</div>

<% }) %>

<% } %>