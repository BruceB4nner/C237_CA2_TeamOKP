<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products - One Klick Purchase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<%- include('partials/header.ejs') %>

<%
    // Safely extract and format view variables
    const searchVal = (typeof search !== 'undefined' && search) ? String(search) : '';
    const catVal = (typeof selectedCategory !== 'undefined' && selectedCategory) ? String(selectedCategory) : '';
    const sortVal = (typeof selectedSort !== 'undefined' && selectedSort) ? String(selectedSort) : '';
    const minVal = (typeof minPrice !== 'undefined' && minPrice) ? String(minPrice) : '';
    const maxVal = (typeof maxPrice !== 'undefined' && maxPrice) ? String(maxPrice) : '';
    const userObj = (typeof user !== 'undefined') ? user : null;
    const prodList = (typeof products !== 'undefined' && Array.isArray(products)) ? products : [];
    
    const defaultCategories = [
        'toys & collectibles', 'computers & tech', "women's fashion", 
        "men's fashion", 'video gaming', 'furniture & home living', 
        'sports & wellness', 'tickets & vouchers', 'others'
    ];
    const catList = (typeof categories !== 'undefined' && Array.isArray(categories) && categories.length > 0) ? categories : defaultCategories;

    const hasFilters = Boolean(
        searchVal.trim() !== '' || 
        catVal.trim() !== '' || 
        sortVal.trim() !== '' || 
        minVal.trim() !== '' || 
        maxVal.trim() !== ''
    );
%>

<div class="container mt-4">

    <!-- Search, Category, Price Range & Sort Filter Form -->
    <div class="bg-light p-3 rounded shadow-sm mb-3">
        <form method="GET" action="/products" class="row g-2 align-items-center" id="searchForm">
            
            <!-- Instant Live Search Input -->
            <div class="col-lg-3 col-md-6">
                <input 
                    type="text" 
                    id="liveSearchInput"
                    class="form-control" 
                    name="search" 
                    value="<%= searchVal %>" 
                    placeholder="⚡ Search products..."
                    autocomplete="off"
                >
            </div>

            <!-- Category Dropdown Filter -->
            <div class="col-lg-2 col-md-6">
                <select name="category" id="categorySelect" class="form-select text-capitalize" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    <% catList.forEach(function(cat) { %>
                        <option value="<%= cat %>" <%= catVal === cat ? 'selected' : '' %>>
                            <%= cat %>
                        </option>
                    <% }); %>
                </select>
            </div>

            <!-- Price Range Inputs -->
            <div class="col-lg-3 col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white">$</span>
                    <input type="number" step="0.01" min="0" name="minPrice" class="form-control" placeholder="Min" value="<%= minVal %>">
                    <span class="input-group-text bg-white">-</span>
                    <input type="number" step="0.01" min="0" name="maxPrice" class="form-control" placeholder="Max" value="<%= maxVal %>">
                </div>
            </div>

            <!-- Sort By Dropdown Filter -->
            <div class="col-lg-2 col-md-6">
                <select name="sort" id="sortSelect" class="form-select" onchange="this.form.submit()">
                    <option value="">Sort: Featured</option>
                    <option value="price_asc" <%= sortVal === 'price_asc' ? 'selected' : '' %>>Price: Low to High</option>
                    <option value="price_desc" <%= sortVal === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
                    <option value="newest" <%= sortVal === 'newest' ? 'selected' : '' %>>Newest Listings</option>
                </select>
            </div>

            <!-- Action Buttons -->
            <div class="col-lg-2 col-md-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100 fw-semibold">Filter</button>
                <a href="/products" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>

    <!-- Active Filter Badges & Results Counter Bar -->
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 bg-white p-2 border-bottom">
        
        <!-- Dynamic Results Counter -->
        <div class="text-secondary fw-semibold">
            <span id="resultsCount" class="text-primary fs-5 fw-bold"><%= prodList.length %></span> 
            <span id="resultsText">product<%= prodList.length === 1 ? '' : 's' %> found</span>
        </div>

        <!-- Filter Chips Container -->
        <div class="d-flex flex-wrap gap-2 align-items-center" id="activeBadgesContainer">
            <% if (searchVal.trim() !== '') { %>
                <span class="badge bg-primary fs-6 d-inline-flex align-items-center gap-1">
                    Search: "<%= searchVal %>"
                    <a href="/products?category=<%= catVal %>&sort=<%= sortVal %>&minPrice=<%= minVal %>&maxPrice=<%= maxVal %>" class="text-white text-decoration-none ms-1" title="Remove search filter">&times;</a>
                </span>
            <% } %>

            <% if (catVal.trim() !== '') { %>
                <span class="badge bg-secondary fs-6 d-inline-flex align-items-center gap-1 text-capitalize">
                    Category: <%= catVal %>
                    <a href="/products?search=<%= searchVal %>&sort=<%= sortVal %>&minPrice=<%= minVal %>&maxPrice=<%= maxVal %>" class="text-white text-decoration-none ms-1" title="Remove category filter">&times;</a>
                </span>
            <% } %>

            <% if (minVal.trim() !== '') { %>
                <span class="badge bg-success fs-6 d-inline-flex align-items-center gap-1">
                    Min Price: $<%= minVal %>
                    <a href="/products?search=<%= searchVal %>&category=<%= catVal %>&sort=<%= sortVal %>&maxPrice=<%= maxVal %>" class="text-white text-decoration-none ms-1" title="Remove min price">&times;</a>
                </span>
            <% } %>

            <% if (maxVal.trim() !== '') { %>
                <span class="badge bg-success fs-6 d-inline-flex align-items-center gap-1">
                    Max Price: $<%= maxVal %>
                    <a href="/products?search=<%= searchVal %>&category=<%= catVal %>&sort=<%= sortVal %>&minPrice=<%= minVal %>" class="text-white text-decoration-none ms-1" title="Remove max price">&times;</a>
                </span>
            <% } %>

            <% if (sortVal.trim() !== '') { %>
                <span class="badge bg-info text-dark fs-6 d-inline-flex align-items-center gap-1">
                    Sort: <%= sortVal === 'price_asc' ? 'Price: Low to High' : (sortVal === 'price_desc' ? 'Price: High to Low' : 'Newest') %>
                    <a href="/products?search=<%= searchVal %>&category=<%= catVal %>&minPrice=<%= minVal %>&maxPrice=<%= maxVal %>" class="text-dark text-decoration-none ms-1" title="Remove sort filter">&times;</a>
                </span>
            <% } %>

            <% if (hasFilters) { %>
                <a href="/products" class="btn btn-sm btn-link text-danger p-0 text-decoration-none fw-semibold">Clear All</a>
            <% } %>
        </div>
    </div>

    <!-- Header Action Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0 fw-bold">Product Catalog</h2>

        <% if (userObj) { %>
            <a href="/addProduct" class="btn btn-success fw-semibold">+ Add Product</a>
        <% } %>
    </div>

    <!-- Product Grid Container -->
    <% if (prodList.length === 0) { %>
        <div class="text-center py-5">
            <div class="alert alert-warning py-4 shadow-sm">
                <h5 class="fw-bold">No products found matching your request.</h5>
                <p class="mb-0 text-muted">Try adjusting your search terms, price range, or category filter.</p>
                <a href="/products" class="btn btn-sm btn-primary mt-3">View All Products</a>
            </div>
        </div>
    <% } else { %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" id="productGrid">
            <% prodList.forEach(function(product) { %>
                <% 
                    const pName = product.productName || 'Untitled Product';
                    const pPrice = parseFloat(product.price || 0).toFixed(2);
                    const pImg = product.image || 'https://via.placeholder.com/300x180?text=No+Image';
                    const pCat = product.category || 'others';
                    const pStock = product.stock || 0;
                    const pDesc = product.description || 'No detailed description available for this product.';
                %>
                <div class="col product-card-col" data-name="<%= pName.toLowerCase() %>">
                    <div class="card h-100 shadow-sm border-0">
                        <a href="/products/<%= product.productId %>" class="text-decoration-none text-dark">
                            <img 
                                src="<%= pImg %>" 
                                class="card-img-top" 
                                style="height:180px; object-fit:cover;" 
                                alt="<%= pName %>"
                            >
                            <div class="card-body text-center d-flex flex-column pb-1">
                                <span class="badge bg-secondary mb-2 text-capitalize align-self-center"><%= pCat %></span>
                                <h5 class="card-title h6 fw-bold mb-1 product-title"><%= pName %></h5>
                                <p class="card-text text-danger fw-bold fs-5 my-1">$<%= pPrice %></p>
                                <p class="card-text mb-2"><small class="text-muted">Stock: <%= pStock %></small></p>

                                <% if (userObj && userObj.role === 'admin') { %>
                                    <form action="/products/delete/<%= product.productId %>" method="POST" class="mt-auto mb-2">
                                        <button type="submit" class="btn btn-danger btn-sm w-100" onclick="return confirm('Admin: Delete this item?')">Delete (Admin)</button>
                                    </form>
                                <% } %>
                            </div>
                        </a>

                        <!-- Quick View Action Button -->
                        <div class="px-3 pb-3 pt-0">
                            <button 
                                type="button" 
                                class="btn btn-outline-primary btn-sm w-100 fw-semibold" 
                                data-bs-toggle="modal" 
                                data-bs-target="#quickViewModal"
                                data-name="<%= pName %>"
                                data-price="<%= pPrice %>"
                                data-category="<%= pCat %>"
                                data-image="<%= pImg %>"
                                data-stock="<%= pStock %>"
                                data-description="<%= pDesc %>"
                                data-id="<%= product.productId %>"
                            >
                                👁️ Quick View
                            </button>
                        </div>

                        <% if (userObj && userObj.userId == product.userId) { %>
                            <div class="card-footer bg-light d-flex justify-content-between align-items-center">
                                <a href="/editProduct/<%= product.productId %>" class="btn btn-warning btn-sm">Edit</a>
                                <form action="/products/delete/<%= product.productId %>" method="POST" class="m-0">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this listing?')">Delete</button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                </div>
            <% }); %>
        </div>

        <div id="noLiveResults" class="text-center py-5 d-none">
            <div class="alert alert-warning py-4 shadow-sm">
                <h5 class="fw-bold">No products match what you're typing.</h5>
                <p class="mb-0 text-muted">Try typing a different name or keyword!</p>
            </div>
        </div>
    <% } %>

</div>

<!-- Quick View Product Bootstrap Modal -->
<div class="modal fade" id="quickViewModal" tabindex="-1" aria-labelledby="quickViewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="quickViewModalLabel">Product Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-4 align-items-center">
                    <div class="col-md-5 text-center">
                        <img id="qvImage" src="" class="img-fluid rounded shadow-sm w-100" style="max-height: 280px; object-fit: cover;" alt="Product Image">
                    </div>
                    <div class="col-md-7">
                        <span id="qvCategory" class="badge bg-secondary text-capitalize mb-2">Category</span>
                        <h3 id="qvName" class="fw-bold mb-2">Product Name</h3>
                        <h4 id="qvPrice" class="text-danger fw-bold my-2">$0.00</h4>
                        <p id="qvStock" class="text-muted small mb-3">Stock: 0</p>
                        <p id="qvDescription" class="text-secondary small bg-light p-3 rounded">Description goes here...</p>
                        <hr>
                        <div class="d-flex gap-2">
                            <a id="qvFullDetailsBtn" href="#" class="btn btn-primary fw-semibold flex-grow-1">View Details Page</a>
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<br>
<%- include('partials/footer.ejs') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- Client-side Interactive Scripts -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Quick View Modal Script
    const quickViewModal = document.getElementById('quickViewModal');
    if (quickViewModal) {
      quickViewModal.addEventListener('show.bs.modal', (event) => {
        const button = event.relatedTarget;
        if (!button) return;

        document.getElementById('qvName').textContent = button.getAttribute('data-name');
        document.getElementById('qvPrice').textContent = '$' + button.getAttribute('data-price');
        document.getElementById('qvCategory').textContent = button.getAttribute('data-category');
        document.getElementById('qvImage').src = button.getAttribute('data-image');
        document.getElementById('qvImage').alt = button.getAttribute('data-name');
        document.getElementById('qvStock').textContent = 'Stock: ' + button.getAttribute('data-stock') + ' available';
        document.getElementById('qvDescription').textContent = button.getAttribute('data-description');
        document.getElementById('qvFullDetailsBtn').href = '/products/' + button.getAttribute('data-id');
      });
    }

    // 2. Live Search & Text Highlighting Script
    const liveInput = document.getElementById('liveSearchInput');
    const productCols = document.querySelectorAll('.product-card-col');
    const noLiveResults = document.getElementById('noLiveResults');
    const resultsCountEl = document.getElementById('resultsCount');
    const resultsTextEl = document.getElementById('resultsText');

    productCols.forEach(col => {
      const titleEl = col.querySelector('.product-title');
      if (titleEl) {
        titleEl.dataset.originalText = titleEl.textContent;
      }
    });

    if (liveInput) {
      liveInput.addEventListener('input', function() {
        const rawQuery = this.value.trim();
        const lowerQuery = rawQuery.toLowerCase();
        let visibleCount = 0;

        if (lowerQuery === '') {
          productCols.forEach(col => {
            col.classList.remove('d-none');
            const titleEl = col.querySelector('.product-title');
            if (titleEl && titleEl.dataset.originalText) {
              titleEl.textContent = titleEl.dataset.originalText;
            }
          });

          if (noLiveResults) noLiveResults.classList.add('d-none');
          if (resultsCountEl) resultsCountEl.textContent = productCols.length;
          if (resultsTextEl) resultsTextEl.textContent = productCols.length === 1 ? 'product found' : 'products found';
          return;
        }

        const queryWords = lowerQuery.split(/\s+/).filter(w => w.length > 0);
        const pattern = queryWords.map(word => `\\b${word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}`).join('.*');
        const searchRegex = new RegExp(pattern, 'i');

        const highlightPattern = queryWords.map(word => word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')).join('|');
        const highlightRegex = new RegExp(`(${highlightPattern})`, 'gi');

        productCols.forEach(col => {
          const productName = col.getAttribute('data-name') || '';
          const titleEl = col.querySelector('.product-title');
          const originalText = titleEl ? (titleEl.dataset.originalText || titleEl.textContent) : '';

          if (searchRegex.test(productName)) {
            col.classList.remove('d-none');
            visibleCount++;

            if (titleEl && highlightPattern) {
              titleEl.innerHTML = originalText.replace(
                highlightRegex, 
                '<mark class="bg-warning text-dark px-1 rounded-1">$1</mark>'
              );
            }
          } else {
            col.classList.add('d-none');
            if (titleEl) {
              titleEl.textContent = originalText;
            }
          }
        });

        if (resultsCountEl) resultsCountEl.textContent = visibleCount;
        if (resultsTextEl) resultsTextEl.textContent = visibleCount === 1 ? 'product found' : 'products found';

        if (visibleCount === 0 && productCols.length > 0) {
          if (noLiveResults) noLiveResults.classList.remove('d-none');
        } else {
          if (noLiveResults) noLiveResults.classList.add('d-none');
        }
      });

      if (liveInput.value.trim() !== '') {
        liveInput.dispatchEvent(new Event('input'));
      }
    }
  });
</script>
</body>
</html>