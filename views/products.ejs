<!DOCTYPE html>
<html>

<head>
    <title>Products</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>

<div class="container mt-4">

    <!-- Sell Item Button -->
    <div class="d-flex justify-content-end mb-3">
        <a href="/addProduct" class="btn btn-success">
            + Sell Item
        </a>
    </div>

    <!-- Search Bar -->
    <form method="GET" action="/products" class="d-flex mb-4">
        <input
            type="text"
            class="form-control me-2"
            name="search"
            value="<%= search %>"
            placeholder="Search products...">

        <button type="submit" class="btn btn-primary">
            Search
        </button>
    </form>

    <h2 class="mb-4">Product Catalog</h2>

    <% if (products.length === 0) { %>

        <p>No products found.</p>

    <% } else { %>

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

            <% products.forEach(product => { %>

                <div class="col">

                    <div class="card h-100 shadow-sm">

                        <img
                            src="<%= product.image %>"
                            class="card-img-top"
                            style="height:200px; object-fit:cover;"
                            alt="<%= product.productName %>">

                        <div class="card-body">

                            <h5 class="card-title">
                                <%= product.productName %>
                            </h5>

                            <p class="card-text">
                                <strong>Price:</strong>
                                $<%= product.price %>
                            </p>

                            <p class="card-text">
                                <strong>Category:</strong>
                                <%= product.category %>
                            </p>

                            <% if (product.description) { %>
                                <p class="card-text">
                                    <%= product.description %>
                                </p>
                            <% } %>

                            <p class="card-text">
                                <strong>Quantity:</strong>
                                <%= product.quantity %>
                            </p>

                            <p class="card-text">
                                <small class="text-muted">
                                    Stock: <%= product.stock %>
                                </small>
                            </p>

                        </div>

                        <!-- ONLY OWNER CAN SEE THESE BUTTONS -->
                        <% if (user && user.userId == product.userId) { %>

                            <div class="card-footer d-flex justify-content-between">

                                <a href="/editProduct/<%= product.productId %>"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <form action="/products/delete/<%= product.productId %>" method="POST">

                                    <button
                                        type="submit"
                                        class="btn btn-danger btn-sm"
                                        onclick="return confirm('Delete this listing?')">
                                        Delete
                                    </button>

                                </form>

                            </div>

                        <% } %>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>

</body>
</html>