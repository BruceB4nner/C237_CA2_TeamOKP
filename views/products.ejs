<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products - One Klick Purchase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<%- include('partials/header.ejs') %>

<div class="container mt-4">

    <!-- Search & Category Filter Section -->
    <div class="bg-light p-3 rounded shadow-sm mb-4">
        <form method="GET" action="/products" class="row g-2 align-items-center" id="searchForm">
            <!-- Instant Live Search Input -->
            <div class="col-md-5">
                <input 
                    type="text" 
                    id="liveSearchInput"
                    class="form-control" 
                    name="search" 
                    value="<%= typeof search !== 'undefined' ? search : '' %>" 
                    placeholder="⚡ Type here to search live..."
                    autocomplete="off"
                >
            </div>

            <!-- Category Dropdown Filter -->
            <div class="col-md-4">
                <select name="category" id="categorySelect" class="form-select text-capitalize">
                    <option value="">All Categories</option>
                    <% 
                        const defaultCategories = [
                            'toys & collectibles', 'computers & tech', "women's fashion", 
                            "men's fashion", 'video gaming', 'furniture & home living', 
                            'sports & wellness', 'tickets & vouchers', 'others'
                        ];
                        const catList = (typeof categories !== 'undefined' && categories.length > 0) ? categories : defaultCategories;
                        const currentCat = typeof selectedCategory !== 'undefined' ? selectedCategory : '';
                    %>
                    <% catList.forEach(cat => { %>
                        <option value="<%= cat %>" <%= currentCat === cat ? 'selected' : '' %>>
                            <%= cat %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <!-- Action Buttons -->
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
                <a href="/products" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>

    <!-- Header Action Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0 fw-bold">Product Catalog</h2>

        <% if (typeof user !== 'undefined' && user) { %>
            <a href="/addProduct" class="btn btn-success fw-semibold">+ Add Product</a>
        <% } %>
    </div>

    <!-- Product Grid Container -->
    <% if (!products || products.length === 0) { %>
        <!-- Empty Database / Server Search Message -->
        <div class="text-center py-5">
            <div class="alert alert-warning py-4 shadow-sm">
                <h5 class="fw-bold">No products found matching your request.</h5>
                <p class="mb-0 text-muted">Try adjusting your search terms or selecting a different category filter.</p>
                <a href="/products" class="btn btn-sm btn-primary mt-3">View All Products</a>
            </div>
        </div>
    <% } else { %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" id="productGrid">
            <% products.forEach(product => { %>
                <!-- Added data-name attribute for Instant Live Searching -->
                <div class="col product-card-col" data-name="<%= product.productName.toLowerCase() %>">
                    <div class="card h-100 shadow-sm border-0">
                        <a href="/products/<%= product.productId %>" class="text-decoration-none text-dark">
                            <img 
                                src="<%= product.image || 'https://via.placeholder.com/300x180?text=No+Image' %>" 
                                class="card-img-top" 
                                style="height:180px; object-fit:cover;" 
                                alt="<%= product.productName %>"
                            >
                            <div class="card-body text-center d-flex flex-column">
                                <% if (product.category) { %>
                                    <span class="badge bg-secondary mb-2 text-capitalize align-self-center"><%= product.category %></span>
                                <% } %>
                                <h5 class="card-title h6 fw-bold mb-1 product-title"><%= product.productName %></h5>
                                <p class="card-text text-danger fw-bold fs-5 my-1">$<%= parseFloat(product.price).toFixed(2) %></p>
                                <p class="card-text"><small class="text-muted">Stock: <%= product.stock %></small></p>

                                <!-- Admin Delete Button -->
                                <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
                                    <form action="/products/delete/<%= product.productId %>" method="POST" class="mt-auto">
                                        <button type="submit" class="btn btn-danger btn-sm w-100 mt-2" onclick="return confirm('Admin: Delete this item?')">Delete (Admin)</button>
                                    </form>
                                <% } %>
                            </div>
                        </a>

                        <!-- Seller Control Footer -->
                        <% if (typeof user !== 'undefined' && user && user.userId == product.userId) { %>
                            <div class="card-footer bg-light d-flex justify-content-between align-items-center">
                                <a href="/editProduct/<%= product.productId %>" class="btn btn-warning btn-sm">Edit</a>
                                <form action="/products/delete/<%= product.productId %>" method="POST" class="m-0">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this listing?')">Delete</button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- Live Search Zero Results Alert (Hidden by default) -->
        <div id="noLiveResults" class="text-center py-5 d-none">
            <div class="alert alert-warning py-4 shadow-sm">
                <h5 class="fw-bold">No products match what you're typing.</h5>
                <p class="mb-0 text-muted">Try typing a different name or keyword!</p>
            </div>
        </div>
    <% } %>

</div>

<br>
<%- include('partials/footer.ejs') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- NING XIN: Instant Live Search Client-Side Script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const liveInput = document.getElementById('liveSearchInput');
    const productCols = document.querySelectorAll('.product-card-col');
    const noLiveResults = document.getElementById('noLiveResults');

    if (liveInput) {
      liveInput.addEventListener('input', function() {
        const query = this.value.toLowerCase().trim();
        let visibleCount = 0;

        productCols.forEach(col => {
          const productName = col.getAttribute('data-name') || '';
          
          if (productName.includes(query)) {
            col.classList.remove('d-none'); // Show card
            visibleCount++;
          } else {
            col.classList.add('d-none'); // Hide card
          }
        });

        // Toggle "No matches" alert if everything is filtered out
        if (visibleCount === 0 && productCols.length > 0) {
          noLiveResults.classList.remove('d-none');
        } else {
          noLiveResults.classList.add('d-none');
        }
      });
    }
  });
</script>
</body>
</html>