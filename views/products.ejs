<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products - One Klick Purchase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

</head>
<body>

<%- include('partials/header.ejs') %>

<div class="container mt-4">

    <!-- Search & Category Filter Section (Ning Xin) -->
    <div class="bg-light p-3 rounded shadow-sm mb-4">
        <form method="GET" action="/products" class="row g-2 align-items-center">
            <!-- Keyword Search -->
            <div class="col-md-5">
                <input 
                    type="text" 
                    class="form-control" 
                    name="search" 
                    value="<%= typeof search !== 'undefined' ? search : '' %>" 
                    placeholder="Search product name..."
                >
            </div>

            <!-- Category Dropdown Filter (Ning Xin) -->
            <div class="col-md-4">
                <select name="category" class="form-select text-capitalize">
                    <option value="">All Categories</option>
                    <% 
                const defaultCategories = [
                'toys & collectibles', 'computers & tech', "women's fashion", 
                "men's fashion", 'video gaming', 'furniture & home living', 
                'sports & wellness', 'tickets & vouchers', 'others'
                ];
                const catList = (typeof categories !== 'undefined' && categories.length > 0) ? categories : defaultCategories;
                const currentCat = typeof selectedCategory !== 'undefined' ? selectedCategory : '';
                    %>
                        const catList = (typeof categories !== 'undefined' && categories.length > 0) ? categories : defaultCategories;
                        const currentCat = typeof selectedCategory !== 'undefined' ? selectedCategory : '';
                    %>
                    <% catList.forEach(cat => { %>
                        <option value="<%= cat %>" <%= currentCat === cat ? 'selected' : '' %>>
                            <%= cat %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <!-- Filter Action Buttons -->
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
                <a href="/products" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>

    <!-- Header Action Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0 fw-bold">Product Catalog</h2>

        <% if (typeof user !== 'undefined' && user) { %>
            <a href="/addProduct" class="btn btn-success fw-semibold">+ Add Product</a>
        <% } %>
    </div>

    <!-- Active Search Indicator -->
    <% if ((typeof search !== 'undefined' && search) || (typeof selectedCategory !== 'undefined' && selectedCategory)) { %>
        <div class="alert alert-info py-2 mb-4 small">
            Showing results for: 
            <% if (search) { %> <strong>Name: "<%= search %>"</strong> <% } %>
            <% if (search && selectedCategory) { %> | <% } %>
            <% if (selectedCategory) { %> <strong>Category: "<%= selectedCategory %>"</strong> <% } %>
        </div>
    <% } %>

    <!-- Product Grid -->
    <% if (!products || products.length === 0) { %>
        <!-- Enhanced Fallback messaging for empty searches (Ning Xin) -->
        <div class="text-center py-5">
            <div class="alert alert-warning py-4 shadow-sm">
                <h5 class="fw-bold">No products found matching your request.</h5>
                <p class="mb-0 text-muted">Try adjusting your search terms or choosing a different category filter.</p>
                <a href="/products" class="btn btn-sm btn-primary mt-3">View All Products</a>
            </div>
        </div>
    <% } else { %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            <% products.forEach(product => { %>
                <div class="col">
                    <div class="card h-100 shadow-sm">

  <!-- Dropdown menu -->
  <div class="card-header bg-transparent border-0 d-flex justify-content-end">
    <% if (user && user.userId == product.userId) { %>
      <div class="dropdown">
        <button class="btn btn-sm btn-light" type="button" data-bs-toggle="dropdown">
          <i class="bi bi-three-dots-vertical"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><a class="dropdown-item" href="/editProduct/<%= product.productId %>">Edit</a></li>
          <li>
            <form action="/products/delete/<%= product.productId %>" method="POST" style="display:inline;">
              <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Delete this listing?')">Delete</button>
            </form>
          </li>
        </ul>
      </div>
    <% } %>
  </div>

  <!-- Product image -->
  <img src="<%= product.image %>" class="card-img-top" style="height:180px; object-fit:cover;" alt="<%= product.productName %>">

  <!-- Product details -->
  <div class="card-body text-center">
    <h5 class="card-title"><%= product.productName %></h5>
    <p class="card-text">$<%= product.price %></p>
    <p class="card-text"><small class="text-muted">Stock: <%= product.stock %></small></p>

    <!-- View Product button -->
    <a href="/products/<%= product.productId %>" class="btn btn-primary btn-sm mt-2">View Product</a>
  </div>
</div>

                </div>
            <% }) %>
        </div>
    <% } %>

</div>

<br>
<%- include('partials/footer.ejs') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
