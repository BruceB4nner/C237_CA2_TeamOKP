<!DOCTYPE html>
<html>

<head>
  <title>Products</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>

<div class="container mt-4">

  <!-- Sell Item Button -->
  <div class="d-flex justify-content-end mb-3">
    <a href="/addProduct" class="btn btn-success">
      + Sell Item
    </a>
  </div>

  <!-- Search Bar -->
  <form method="GET" action="/products" class="d-flex mb-4">
    <input
      type="text"
      class="form-control me-2"
      name="search"
      value="<%= search %>"
      placeholder="Search products...">

    <button class="btn btn-primary" type="submit">
      Search
    </button>
  </form>

  <h2 class="mb-3">Product Catalog</h2>

  <% if (products.length === 0) { %>

      <p>No products found.</p>

  <% } else { %>

      <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

        <% products.forEach(product => { %>

          <div class="col">

            <div class="card h-100 shadow-sm">

              <a href="/product/<%= product.productId %>" class="text-decoration-none text-dark">

                <img
                  src="<%= product.image %>"
                  class="card-img-top"
                  style="height:180px; object-fit:cover;"
                  alt="<%= product.productName %>">

                <div class="card-body text-center">

                  <h5 class="card-title">
                    <%= product.productName %>
                  </h5>

                  <p class="card-text">
                    $<%= product.price %>
                  </p>

                  <p class="card-text">
                    Category: <%= product.category %>
                  </p>

                  <p class="card-text">
                    <small class="text-muted">
                      Stock: <%= product.stock %>
                    </small>
                  </p>

                </div>

              </a>

              <!-- Only owner can edit/delete -->
              <% if (user && user.userId === product.userId) { %>

                <div class="card-footer d-flex justify-content-between">

                  <a href="/editProduct/<%= product.productId %>" class="btn btn-warning btn-sm">
                    Edit
                  </a>

                  <a href="/deleteProduct/<%= product.productId %>" class="btn btn-danger btn-sm">
                    Delete
                  </a>

                </div>

              <% } %>

            </div>

          </div>

        <% }) %>

      </div>

  <% } %>

</div>

</body>

</html>