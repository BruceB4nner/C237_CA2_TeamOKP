<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.productName %> - One Klick Purchase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>

<%- include('partials/header.ejs') %>

<div class="container mt-5">
    <!-- Breadcrumb Navigation -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/products" class="text-decoration-none">Products</a></li>
            <li class="breadcrumb-item active text-capitalize" aria-current="page"><%= product.category || 'Product' %></li>
        </ol>
    </nav>

    <div class="row g-5">
        <!-- Product Image Section -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <img 
                    src="<%= product.image || 'https://via.placeholder.com/500x400?text=No+Image' %>" 
                    class="img-fluid rounded" 
                    style="max-height: 450px; width: 100%; object-fit: cover;" 
                    alt="<%= product.productName %>"
                >
            </div>
        </div>

        <!-- Product Information Section -->
        <div class="col-lg-6">
            <span class="badge bg-secondary text-capitalize fs-6 mb-3"><%= product.category || 'Others' %></span>
            <h1 class="fw-bold mb-3"><%= product.productName %></h1>
            <h3 class="text-danger fw-bold mb-3">$<%= parseFloat(product.price || 0).toFixed(2) %></h3>
            
            <p class="mb-3">
                <strong>Stock Status:</strong> 
                <% if (Number(product.stock) > 0) { %>
                    <span class="text-success fw-semibold"><%= product.stock %> available</span>
                <% } else { %>
                    <span class="text-danger fw-semibold">Out of Stock</span>
                <% } %>
            </p>

            <div class="mb-4">
                <h5 class="fw-bold">Description</h5>
                <p class="text-muted"><%= product.description || 'No detailed description provided for this product.' %></p>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex flex-wrap gap-2 mb-4">
                <% if (user) { %>
                    <form action="/wishlist/add/<%= product.productId %>" method="POST" class="m-0">
                        <button type="submit" class="btn btn-outline-danger fw-semibold">❤️ Add to Wishlist</button>
                    </form>
                <% } %>
                <a href="/products" class="btn btn-outline-secondary">Back to Products</a>
            </div>

            <!-- Owner or Admin Management Box -->
            <% if (user && (user.userId == product.userId || user.role === 'admin')) { %>
                <div class="card bg-light border-0 p-3 mt-4 shadow-sm">
                    <h6 class="fw-bold text-muted mb-2">Management Controls</h6>
                    <div class="d-flex gap-2">
                        <% if (user.userId == product.userId) { %>
                            <a href="/editProduct/<%= product.productId %>" class="btn btn-warning btn-sm fw-semibold">Edit Product</a>
                        <% } %>
                        <form action="/products/delete/<%= product.productId %>" method="POST" class="m-0">
                            <button type="submit" class="btn btn-danger btn-sm fw-semibold" onclick="return confirm('Are you sure you want to delete this product?')">Delete Product</button>
                        </form>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<br><br>
<%- include('partials/footer.ejs') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>