<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products - One Klick Purchase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<%- include('partials/header.ejs') %>

<div class="container mt-4">

    <!-- Search, Category & Sort Filter Form -->
    <div class="bg-light p-3 rounded shadow-sm mb-3">
        <form method="GET" action="/products" class="row g-2 align-items-center" id="searchForm">
            
            <!-- Instant Live Search Input -->
            <div class="col-md-4">
                <input 
                    type="text" 
                    id="liveSearchInput"
                    class="form-control" 
                    name="search" 
                    value="<%= typeof search !== 'undefined' ? search : '' %>" 
                    placeholder="⚡ Type here to search live..."
                    autocomplete="off"
                >
            </div>

            <!-- Category Dropdown Filter -->
            <div class="col-md-3">
                <select name="category" id="categorySelect" class="form-select text-capitalize" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    <% 
                        const defaultCategories = [
                            'toys & collectibles', 'computers & tech', "women's fashion", 
                            "men's fashion", 'video gaming', 'furniture & home living', 
                            'sports & wellness', 'tickets & vouchers', 'others'
                        ];
                        const catList = (typeof categories !== 'undefined' && categories.length > 0) ? categories : defaultCategories;
                        const currentCat = typeof selectedCategory !== 'undefined' ? selectedCategory : '';
                        const currentSort = typeof selectedSort !== 'undefined' ? selectedSort : '';
                    %>
                    <% catList.forEach(cat => { %>
                        <option value="<%= cat %>" <%= currentCat === cat ? 'selected' : '' %>>
                            <%= cat %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <!-- Sort By Dropdown Filter -->
            <div class="col-md-3">
                <select name="sort" id="sortSelect" class="form-select" onchange="this.form.submit()">
                    <option value="">Sort By: Featured</option>
                    <option value="price_asc" <%= currentSort === 'price_asc' ? 'selected' : '' %>>Price: Low to High</option>
                    <option value="price_desc" <%= currentSort === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
                    <option value="newest" <%= currentSort === 'newest' ? 'selected' : '' %>>Newest Listings</option>
                </select>
            </div>

            <!-- Action Buttons -->
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
                <a href="/products" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>

    <!-- Active Filter Badges & Results Counter Bar -->
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 bg-white p-2 border-bottom">
        
        <!-- Dynamic Results Counter -->
        <div class="text-secondary fw-semibold">
            <span id="resultsCount" class="text-primary fs-5 fw-bold"><%= products.length %></span> 
            <span id="resultsText">product<%= products.length === 1 ? '' : 's' %> found</span>
        </div>

        <!-- Filter Chips / Badges Container -->
        <div class="d-flex flex-wrap gap-2 align-items-center" id="activeBadgesContainer">
            <% if (typeof search !== 'undefined' && search.trim() !== '') { %>
                <span class="badge bg-primary fs-6 d-inline-flex align-items-center gap-1">
                    Search: "<%= search %>"
                    <a href="/products?category=<%= selectedCategory %>&sort=<%= selectedSort %>" class="text-white text-decoration-none ms-1" title="Remove search filter">&times;</a>
                </span>
            <% } %>

            <% if (typeof selectedCategory !== 'undefined' && selectedCategory.trim() !== '') { %>
                <span class="badge bg-secondary fs-6 d-inline-flex align-items-center gap-1 text-capitalize">
                    Category: <%= selectedCategory %>
                    <a href="/products?search=<%= search %>&sort=<%= selectedSort %>" class="text-white text-decoration-none ms-1" title="Remove category filter">&times;</a>
                </span>
            <% } %>

            <% if (typeof selectedSort !== 'undefined' && selectedSort.trim() !== '') { %>
                <span class="badge bg-info text-dark fs-6 d-inline-flex align-items-center gap-1">
                    Sort: <%= selectedSort === 'price_asc' ? 'Price: Low to High' : (selectedSort === 'price_desc' ? 'Price: High to Low' : 'Newest') %>
                    <a href="/products?search=<%= search %>&category=<%= selectedCategory %>" class="text-dark text-decoration-none ms-1" title="Remove sort filter">&times;</a>
                </span>
            <% } %>

            <% if ((typeof search !== 'undefined' && search.trim() !== '') || (typeof selectedCategory !== 'undefined' && selectedCategory.trim() !== '') || (typeof selectedSort !== 'undefined' && selectedSort.trim() !== '')) { %>
                <a href="/products" class="btn btn-sm btn-link text-danger p-0 text-decoration-none fw-semibold">Clear All</a>
            <% } %>
        </div>
    </div>

    <!-- Header Action Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0 fw-bold">Product Catalog</h2>

        <% if (typeof user !== 'undefined' && user) { %>
            <a href="/addProduct" class="btn btn-success fw-semibold">+ Add Product</a>
        <% } %>
    </div>

    <!-- Product Grid Container -->
    <% if (!products || products.length === 0) { %>
        <div class="text-center py-5">
            <div class="alert alert-warning py-4 shadow-sm">
                <h5 class="fw-bold">No products found matching your request.</h5>
                <p class="mb-0 text-muted">Try adjusting your search terms or selecting a different category filter.</p>
                <a href="/products" class="btn btn-sm btn-primary mt-3">View All Products</a>
            </div>
        </div>
    <% } else { %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" id="productGrid">
            <% products.forEach(product => { %>
                <div class="col product-card-col" data-name="<%= product.productName.toLowerCase() %>">
                    <div class="card h-100 shadow-sm border-0">
                        <a href="/products/<%= product.productId %>" class="text-decoration-none text-dark">
                            <img 
                                src="<%= product.image || 'https://via.placeholder.com/300x180?text=No+Image' %>" 
                                class="card-img-top" 
                                style="height:180px; object-fit:cover;" 
                                alt="<%= product.productName %>"
                            >
                            <div class="card-body text-center d-flex flex-column">
                                <% if (product.category) { %>
                                    <span class="badge bg-secondary mb-2 text-capitalize align-self-center"><%= product.category %></span>
                                <% } %>
                                <h5 class="card-title h6 fw-bold mb-1 product-title"><%= product.productName %></h5>
                                <p class="card-text text-danger fw-bold fs-5 my-1">$<%= parseFloat(product.price).toFixed(2) %></p>
                                <p class="card-text"><small class="text-muted">Stock: <%= product.stock %></small></p>

                                <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
                                    <form action="/products/delete/<%= product.productId %>" method="POST" class="mt-auto">
                                        <button type="submit" class="btn btn-danger btn-sm w-100 mt-2" onclick="return confirm('Admin: Delete this item?')">Delete (Admin)</button>
                                    </form>
                                <% } %>
                            </div>
                        </a>

                        <% if (typeof user !== 'undefined' && user && user.userId == product.userId) { %>
                            <div class="card-footer bg-light d-flex justify-content-between align-items-center">
                                <a href="/editProduct/<%= product.productId %>" class="btn btn-warning btn-sm">Edit</a>
                                <form action="/products/delete/<%= product.productId %>" method="POST" class="m-0">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this listing?')">Delete</button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

        <div id="noLiveResults" class="text-center py-5 d-none">
            <div class="alert alert-warning py-4 shadow-sm">
                <h5 class="fw-bold">No products match what you're typing.</h5>
                <p class="mb-0 text-muted">Try typing a different name or keyword!</p>
            </div>
        </div>
    <% } %>

</div>

<br>
<%- include('partials/footer.ejs') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- NING XIN: In-Order Live Search + Dynamic Counter + Real-Time Text Highlighting Script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const liveInput = document.getElementById('liveSearchInput');
    const productCols = document.querySelectorAll('.product-card-col');
    const noLiveResults = document.getElementById('noLiveResults');
    const resultsCountEl = document.getElementById('resultsCount');
    const resultsTextEl = document.getElementById('resultsText');

    // Save original title text into HTML dataset to allow safe highlighting & resetting
    productCols.forEach(col => {
      const titleEl = col.querySelector('.product-title');
      if (titleEl) {
        titleEl.dataset.originalText = titleEl.textContent;
      }
    });

    if (liveInput) {
      liveInput.addEventListener('input', function() {
        const rawQuery = this.value.trim();
        const lowerQuery = rawQuery.toLowerCase();
        let visibleCount = 0;

        if (lowerQuery === '') {
          // Restore original titles, show all cards
          productCols.forEach(col => {
            col.classList.remove('d-none');
            const titleEl = col.querySelector('.product-title');
            if (titleEl && titleEl.dataset.originalText) {
              titleEl.textContent = titleEl.dataset.originalText;
            }
          });

          if (noLiveResults) noLiveResults.classList.add('d-none');
          if (resultsCountEl) resultsCountEl.textContent = productCols.length;
          if (resultsTextEl) resultsTextEl.textContent = productCols.length === 1 ? 'product found' : 'products found';
          return;
        }

        const queryWords = lowerQuery.split(/\s+/).filter(w => w.length > 0);
        
        // Sequential Search Pattern
        const pattern = queryWords.map(word => `\\b${word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}`).join('.*');
        const searchRegex = new RegExp(pattern, 'i');

        // Highlighting Pattern
        const highlightPattern = queryWords.map(word => word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')).join('|');
        const highlightRegex = new RegExp(`(${highlightPattern})`, 'gi');

        productCols.forEach(col => {
          const productName = col.getAttribute('data-name') || '';
          const titleEl = col.querySelector('.product-title');
          const originalText = titleEl ? (titleEl.dataset.originalText || titleEl.textContent) : '';

          if (searchRegex.test(productName)) {
            col.classList.remove('d-none');
            visibleCount++;

            // Apply yellow highlight tag to matching words
            if (titleEl && highlightPattern) {
              titleEl.innerHTML = originalText.replace(
                highlightRegex, 
                '<mark class="bg-warning text-dark px-1 rounded-1">$1</mark>'
              );
            }
          } else {
            col.classList.add('d-none');
            if (titleEl) {
              titleEl.textContent = originalText;
            }
          }
        });

        // Update live counter
        if (resultsCountEl) resultsCountEl.textContent = visibleCount;
        if (resultsTextEl) resultsTextEl.textContent = visibleCount === 1 ? 'product found' : 'products found';

        // Toggle empty alert
        if (visibleCount === 0 && productCols.length > 0) {
          if (noLiveResults) noLiveResults.classList.remove('d-none');
        } else {
          if (noLiveResults) noLiveResults.classList.add('d-none');
        }
      });

      // Run live highlighting automatically if input was pre-filled on load
      if (liveInput.value.trim() !== '') {
        liveInput.dispatchEvent(new Event('input'));
      }
    }
  });
</script>
</body>
</html>