<!DOCTYPE html>
<html>
<head>
  <title><%= product.productName %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/header.ejs') %>

  <div class="container mt-5">
    <div class="card mx-auto" style="max-width: 600px;">
      <img src="<%= product.image %>" class="card-img-top" alt="<%= product.productName %>">
      <div class="card-body">
        <h3 class="card-title"><%= product.productName %></h3>
        <p class="card-text">Price: $<%= product.price %></p>
        <p class="card-text">Stock: <%= product.stock %></p>
        <p class="card-text">Description: <%= product.description %></p>

        <% if (user && user.role === 'admin') { %>
          <form action="/products/delete/<%= product.productId %>" method="POST">
            <button type="submit" onclick="return confirm('Delete this listing?')" class="btn btn-danger">Delete Product</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>

                        <% if (user) { %>
  <form action="/cart/add/<%= product.productId %>" method="POST" class="mt-3 text-center">
    <button type="submit" class="btn btn-success btn-sm px-3 py-1">Add to Cart</button>
  </form>
<% } else { %>
  <div class="text-center mt-3">
    <a href="/login" class="btn btn-success btn-sm px-3 py-1">Login to Add to Cart</a>
  </div>
<% } %>


  <!-- toast thingy when user adds stuff to cart -->
<div class="position-center">
  <div id="cartToast" class="toast align-items-center text-bg-success border-0" role="alert">
    <div class="d-flex">
      <div class="toast-body">Item added to cart</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('form[action^="/cart/add"]').forEach(form => {
    form.addEventListener('submit', async e => {
      e.preventDefault(); // stop redirect
      // send the request via fetch instead of normal form submit
      const res = await fetch(form.action, {method: 'POST',body: new FormData(form)});

      if (res.ok) {const toastEl = document.getElementById('cartToast');
        const toast = new bootstrap.Toast(toastEl);
        toast.show();} 
        else {alert("Product is unavailable.");}});});
</script>

  <%- include('partials/footer.ejs') %>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
